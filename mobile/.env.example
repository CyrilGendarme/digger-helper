# ── Auth ──────────────────────────────────────────────────────────────────────
# Passcode to unlock the app.
# Compiled into the JS bundle — do not use for sensitive secrets.
EXPO_PUBLIC_PASSCODE=1234

# ── API ───────────────────────────────────────────────────────────────────────
# Local IP of the machine running the backend (e.g. 192.168.1.42)
EXPO_PUBLIC_API_URL=http://192.168.1.42:8000/api/v1
